# URL pública do seu projeto Supabase
SUPABASE_URL=https://<seu-projeto>.supabase.co
# SERVICE ROLE KEY do Supabase (não expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=<sua-service-role-key>

# URL do backend local
VITE_BACKEND_URL=http://localhost:3000/api
# Caso queira proteger o backend, defina também estas duas chaves iguais
BACKEND_API_KEY=<seu-backend-api-key>
VITE_BACKEND_API_KEY=<seu-backend-api-key>

# URL da API Evolution hospedada no Railway
EVOLUTION_API_URL=https://<seu-railway>.railway.app/endpoint
EVOLUTION_API_KEY=<seu_token>
